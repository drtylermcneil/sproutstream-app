# ─────────────────────────────────────────────
# SproutStream — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────

# ── Supabase (supabase.com → Project Settings → API) ──
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Stripe (stripe.com → Developers → API keys) ──
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
# NOTE: Secret key goes in Supabase Edge Functions only — never expose in frontend
# STRIPE_SECRET_KEY=sk_live_...

# ── Cloudflare Stream (dash.cloudflare.com → Stream) ──
VITE_CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
VITE_CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=customer-subdomain.cloudflarestream.com
# NOTE: API token goes in Supabase Edge Functions only — never expose in frontend
# CLOUDFLARE_STREAM_API_TOKEN=your-token
